PORT=4000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:5173

# mock | whisper-cli
TRANSCRIPTION_PROVIDER=mock

# Path to whisper executable if TRANSCRIPTION_PROVIDER=whisper-cli
WHISPER_CLI_PATH=whisper
WHISPER_MODEL=base

# Adapter strategy: mock | instagram-placeholder
REEL_ADAPTER=mock

# Optional local fallback video used by mock adapter
SAMPLE_VIDEO_PATH=

# FFmpeg path override (optional). If empty, ffmpeg-static is used.
FFMPEG_PATH=
